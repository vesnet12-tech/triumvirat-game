rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for the bot server and dashboard.
    // In a production app, the server would use firebase-admin with a service account,
    // and the client would use Firebase Auth.
    match /settings/{settingId} {
      allow read, write: if true;
    }
    
    match /characters/{characterId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
    
    match /parties/{partyId} {
      allow read, write: if true;
    }
  }
}
